<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # No rewrite for existing files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirect everything else to index.html (Vue Router handles it)
    RewriteRule ^ index.html [L]
</IfModule>
